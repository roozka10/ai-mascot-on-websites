{
  "framework": "vite",
  "buildCommand": "npm run build",
  "installCommand": "npm --prefix yetionboarding install",
  "outputDirectory": "yetionboarding/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
