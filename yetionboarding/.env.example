# Vercel: use these exact names, then redeploy (Vite bakes them in at build time)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Also accepted at build time (optional aliases):
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Vercel API routes read these at runtime for Stripe Checkout + webhooks:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
PUBLIC_SITE_URL=https://www.yetiassistant.online
