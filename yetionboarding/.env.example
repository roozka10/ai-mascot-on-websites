# Vercel: use these exact names, then redeploy (Vite bakes them in at build time)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google AdSense (optional — ads show only when both are set)
# 1. Apply at https://www.google.com/adsense
# 2. Add your site, get approved, then create ad units
# 3. Paste your publisher ID (ca-pub-...) and slot IDs below
VITE_ADSENSE_CLIENT=ca-pub-2098929307010637
VITE_ADSENSE_SLOT=
VITE_ADSENSE_SLOT_ACCOUNT=
VITE_ADSENSE_SLOT_FOOTER=

# Also accepted at build time (optional aliases):
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Vercel API routes read these at runtime:
SUPABASE_SERVICE_ROLE_KEY=
PUBLIC_SITE_URL=https://www.yetiassistant.online
